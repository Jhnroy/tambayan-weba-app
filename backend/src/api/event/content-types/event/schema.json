{
  "kind": "collectionType",
  "collectionName": "events",
  "info": {
    "singularName": "event",
    "pluralName": "events",
    "displayName": "Event"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "dateTime": {
      "type": "datetime"
    },
    "location": {
      "type": "string"
    },
    "eventType": {
      "type": "enumeration",
      "enum": [
        "CLEANUP",
        "TREE PLANTING",
        "RELIEF OPERATION",
        "BASKETBALL",
        "VOLLEYBALL",
        "MEETING",
        "SEMINAR",
        "WORKSHOP",
        "FEEDING PROGRAM",
        "MEDICAL MISSION",
        "FUNDRAISING",
        "COMMUNITY SERVICE",
        "SPORTS"
      ]
    },
    "slotLimit": {
      "type": "integer"
    },
    "availableSlots": {
      "type": "integer"
    },
    "stats": {
      "type": "enumeration",
      "enum": [
        "ACTIVE",
        "CANCELLED",
        "COMPLETED"
      ]
    },
    "users_permissions_user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user",
      "inversedBy": "events"
    },
    "participations": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::participation.participation",
      "mappedBy": "event"
    }
  }
}
